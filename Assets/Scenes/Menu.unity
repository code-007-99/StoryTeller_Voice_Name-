  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Welcome to StoryTeller</b>\n\n<b>GAME START</b>\n\u2022 Each player
    is a Tracker travelling through Waterholes.\n\u2022 Choose an Animal Totem (your
    avatar) before the game begins.\n\n<b>MOVEMENT</b>\n\u2022 Roll the rock (dice)
    to move around the board.\n\u2022 Follow the footprints on the board:\n  - White
    footprints move clockwise.\n  - Black footprints move anticlockwise.\n\n<b>ARTIFACTS</b>\n\u2022
    Each time you complete a full lap around the Waterholes you collect an Artifact.\n\u2022
    Artifacts represent cultural knowledge gained during your journey.\n\n<b>SPECIAL
    TILES</b>\n\u2022 Message Stick \u2013 draw a story or knowledge card.\n\u2022
    Gone Walkabout \u2013 skip your next turn and reflect.\n\n<b>MEETING PLACE</b>\n\u2022
    After collecting the required number of Artifacts (usually 4),\n  you may attempt
    to enter the Meeting Place.\n\u2022 To enter the Meeting Place you must roll
    a total of 8 with two rocks (dice).\n\n<b>GOAL</b>\n\u2022 Once inside the Meeting
    Place, choose a Story Card and share the story.\n\u2022 The aim of the game is
    learning, reflection, and storytelling\n  rather than competition."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
